ANTHROPIC_API_KEY=
# Defaults to "claude-sonnet-4-6" if not specified.
# ANTHROPIC_MODEL=

OPENAI_API_KEY=
# Defaults to "text-embedding-3-small" if not specified.
# OPENAI_EMBEDDING_MODEL=
# Defaults to 96.
# OPENAI_EMBEDDING_BATCH_SIZE=

# Use in-memory seeded demo data by default. Change to "firestore" to persist ingested data.
SECONDBRAIN_STORAGE_BACKEND=memory
SECONDBRAIN_SEED_MOCK_DATA=1

# Firestore production credentials. Use one of these when SECONDBRAIN_STORAGE_BACKEND=firestore.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_FILE=
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_DATABASE_URL=
# FIREBASE_STORAGE_BUCKET=

# Firestore emulator, for local persistence without a service account.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Google Drive original PDF uploads. Share the target Drive folder with the
# service account email before ingesting PDFs.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
